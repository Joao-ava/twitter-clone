{
  "name": "twitter-server",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "build": "sucrase ./src -d ./dist --transforms imports",
    "pretest:integration": "cross-env NODE_ENV=test sequelize db:migrate",
    "test": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "test:unit": "npm run test -- --config jest-unit-config.js",
    "test:integration": "npm run test -- --config jest-integration-config.js",
    "posttest:integration": "cross-env NODE_ENV=test sequelize db:migrate:undo:all"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "pg": "^8.22.0",
    "pg-hstore": "^2.3.3",
    "sequelize": "^6.37.8",
    "youch": "^4.1.1",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@sucrase/jest-plugin": "^3.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.6.0",
    "factory-girl": "^5.0.4",
    "jest": "^30.4.2",
    "prettier": "^3.8.5",
    "sequelize-cli": "^6.6.5",
    "sqlite3": "^6.0.1",
    "sucrase": "^3.35.1",
    "supertest": "^7.2.2"
  },
  "imports": {
    "#app/*": "./src/*",
    "#tests/*": "./__tests__/*"
  }
}
